# Example Postgres connection string for local development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ipe_distribuidora"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me"
INTEGRATIONS_SECRET_KEY=""
STORAGE_DRIVER="local"
PUBLIC_BASE_URL="http://localhost:3000"
# In production prefer an absolute path outside the release folder, e.g. /srv/ipe-distribuidora/uploads
LOCAL_UPLOAD_DIR="./public/uploads"
LOCAL_UPLOAD_MAX_SIZE="5242880"
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_BASE_URL=""
PDF_TEMPLATE_VERSION="corporate_v3"
PDF_RENDER_ENGINE="html"
# In production set to false to avoid silent fallback to the legacy native layout.
PDF_HTML_ALLOW_NATIVE_FALLBACK="true"
PDF_HTML_WAIT_UNTIL="networkidle"
# Set the internal app base URL used by Playwright on the server, e.g. http://127.0.0.1:3000
PDF_RENDER_BASE_URL=""
# Set the browser executable path in production, e.g. /usr/bin/google-chrome
PDF_HTML_BROWSER_PATH=""
PDF_FALLBACK_LOGO_PATH="./files/logo.png"
VAREJONLINE_APP_ID=""
VAREJONLINE_APP_SECRET=""
# Example callback URL: http://localhost:3000/api/v2/integrations/callback/VAREJONLINE
VAREJONLINE_REDIRECT_URI=""
